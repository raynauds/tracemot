{
  "name": "@traceword/game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate:tokens": "node scripts/generate-tokens.ts",
    "check:tokens": "node scripts/generate-tokens.ts --check",
    "check:progress": "node tools/progress-check.mjs",
    "check:shared-progress": "node tools/shared-progress-check.mjs",
    "check:rune-logic": "eslint src/logic",
    "check": "tsc --noEmit && npm run check:rune-logic && npm run check:progress && npm run check:shared-progress && npm run check:tokens",
    "i18n:extract": "npx rune@latest extract-translations"
  },
  "dependencies": {
    "@traceword/core": "*",
    "pixi.js": "^8.19.0",
    "rune-sdk": "^6.0.1"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "vite": "^8.1.4"
  }
}
