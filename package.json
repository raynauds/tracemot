{
  "name": "tracemot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @tracemot/game",
    "build": "npm run build -w @tracemot/game",
    "preview": "npm run preview -w @tracemot/game",
    "generate:levels": "npm run generate:levels -w @tracemot/studio",
    "generate:tokens": "npm run generate:tokens -w @tracemot/game",
    "check:tokens": "npm run check:tokens -w @tracemot/game",
    "check:solver": "npm run check:solver -w @tracemot/studio",
    "check:progress": "npm run check:progress -w @tracemot/game",
    "check": "npm run check --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
