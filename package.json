{
  "name": "traceword",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @traceword/game",
    "build": "npm run build -w @traceword/game",
    "preview": "npm run preview -w @traceword/game",
    "upload": "npm run upload -w @traceword/game",
    "generate:levels": "npm run generate:levels -w @traceword/studio",
    "generate:tokens": "npm run generate:tokens -w @traceword/game",
    "check:tokens": "npm run check:tokens -w @traceword/game",
    "check:solver": "npm run check:solver -w @traceword/studio",
    "check:progress": "npm run check:progress -w @traceword/game",
    "check": "npm run check --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "overrides": {
    "ts-api-utils": {
      "typescript": "^5.9.0"
    }
  }
}
